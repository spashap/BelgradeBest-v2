# ---- Public site (Vercel build env) ----
# Google Analytics 4 measurement id. Injected into <head> in production only.
PUBLIC_GA4_ID=

# ---- /admin (server functions — set these in the Vercel project env) ----
# Persistence: /admin commits settings changes back to the repo via the GitHub
# API, which auto-triggers a rebuild. A fine-grained token with Contents:write
# on this repo. (Unset locally → /admin edits the local file directly in dev.)
GITHUB_TOKEN=
GITHUB_REPO=spashap/BelgradeBest-v2
GITHUB_BRANCH=main

# Optional auth — UNSET = /admin is OPEN (no login). Set it to require a password.
ADMIN_PASSWORD=

# Analytics in /admin (GA4 Data API). GA_CREDENTIALS_JSON = inline service-account
# JSON (Vercel-friendly); locally you can use GOOGLE_APPLICATION_CREDENTIALS instead.
GA_PROPERTY_ID=
GA_CREDENTIALS_JSON=
VERCEL_TEAM_ID=

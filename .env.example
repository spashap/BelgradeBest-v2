# ---- Public site (Vercel build env) ----
# Google Analytics 4 measurement id. Injected into <head> in production only.
PUBLIC_GA4_ID=

# ---- Local-only admin (admin/.env, never committed, never deployed) ----
# GA4 Data API (service account)
GA_PROPERTY_ID=
GOOGLE_APPLICATION_CREDENTIALS=
# Vercel Web Analytics API
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

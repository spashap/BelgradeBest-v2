---
// Visible FAQ accordion (pairs with faqSchema() JSON-LD). Native <details> so it
// needs no JS and stays accessible. Reusable: pass any [{question, answer}].
interface FaqItem {
  question: string;
  answer: string;
}
interface Props {
  faqs?: FaqItem[];
}
const { faqs = [] } = Astro.props;
---
{
  faqs.length > 0 ? (
    <div class="c-faq">
      {faqs.map((f) => (
        <details class="c-faq__item">
          <summary class="c-faq__q">{f.question}</summary>
          <p class="c-faq__a">{f.answer}</p>
        </details>
      ))}
    </div>
  ) : null
}

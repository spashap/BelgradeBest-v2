---
import Container from "./Container.astro";
import { CONFIG, interp } from "../lib/site";
import { clusterBySlug, utilityPages } from "../lib/clusters";
import { areaSection } from "../lib/areas";
import { glossarySection } from "../lib/glossary";
import { VERSION } from "../lib/version";

// Footer from chrome.footer + DERIVED links (leg titles/hrefs from clusters,
// utility-page titles/paths from utilityPages). Degrades to a one-line footer
// when no footer config is present.
type ResolvedLink = { title: string; href: string };

// Footer list items are { ref, visible } (admin-controlled); a bare string is
// tolerated as { ref, visible:true }. Hidden items drop out before resolving.
type RefItem = string | { ref: string; visible?: boolean };
function visibleRefs(items: RefItem[]): string[] {
  return items
    .map((it) => (typeof it === "string" ? { ref: it, visible: true } : it))
    .filter((it) => it.visible !== false)
    .map((it) => it.ref);
}

// Standalone sections that aren't legs or utility pages (e.g. the programmatic
// /areas hub). Gated on their publish flag so a footer ref auto-hides if the
// section is turned off. Resolves regardless of the column's `kind`.
const prog = (CONFIG as { programmatic?: { areasIndexable?: boolean; glossaryIndexable?: boolean } }).programmatic;
const SPECIAL: Record<string, ResolvedLink> = {
  ...(prog?.areasIndexable === true
    ? { [areaSection.slug]: { title: areaSection.title, href: `/${areaSection.slug}` } }
    : {}),
  ...(prog?.glossaryIndexable === true
    ? { [glossarySection.slug]: { title: glossarySection.title, href: `/${glossarySection.slug}` } }
    : {}),
  // The platform pitch page — footer-labelled "Partners" (owner decision
  // 2026-07-05, replacing the how-we-make-money footer slot).
  "for-businesses": { title: "Partners", href: "/for-businesses" },
};

function resolveRef(kind: string, slug: string): ResolvedLink | null {
  if (SPECIAL[slug]) return SPECIAL[slug];
  if (kind === "legs") {
    const c = clusterBySlug(slug);
    // Master gate: a leg hidden in the structure (visible:false) drops from the
    // footer too, regardless of its footer-item flag.
    return c && !c.hidden ? { title: c.title, href: c.href } : null;
  }
  const p = utilityPages.find((u) => u.slug === slug);
  return p ? { title: p.title, href: `/${p.slug}` } : null;
}

const year = new Date().getFullYear();
const copyright = interp(CONFIG.chrome.footerLine, { year });
const f = CONFIG.chrome.footer as
  | {
      showBrand?: boolean;
      columns?: { heading?: string; kind: string; items?: RefItem[] }[];
      legal?: RefItem[];
      social?: { url: string; label: string; visible?: boolean }[];
    }
  | undefined;

const columns = ((f?.columns ?? []) as { heading?: string; kind: string; items?: RefItem[] }[])
  .map((col) => ({
    heading: String(col.heading ?? ""),
    items: visibleRefs(col.items ?? [])
      .map((s) => resolveRef(col.kind, s))
      .filter((x): x is ResolvedLink => x !== null),
  }))
  .filter((col) => col.items.length > 0);
const legal = visibleRefs(f?.legal ?? [])
  .map((s) => resolveRef("pages", s))
  .filter((x): x is ResolvedLink => x !== null);
const social = ((f?.social ?? []) as { url: string; label: string; visible?: boolean }[]).filter(
  (s) => s && s.url && s.label && s.visible !== false,
);
---
{
  !f ? (
    <footer class="c-site-footer">
      <Container>
        <p>{copyright} · {VERSION}</p>
      </Container>
    </footer>
  ) : (
    <footer class="c-site-footer">
      <Container>
        <div class="c-footer">
          {f.showBrand ? (
            <div class="c-footer__brand">
              <a href="/" class="c-footer__brandname">
                {CONFIG.brand.name}
              </a>
              <p>{CONFIG.brand.tagline}.</p>
            </div>
          ) : null}
          <div class="c-footer__cols">
            {columns.map((col) => (
              <nav class="c-footer__col">
                <h2 class="c-footer__heading">{col.heading}</h2>
                <ul>
                  {col.items.map((it) => (
                    <li>
                      <a href={it.href}>{it.title}</a>
                    </li>
                  ))}
                </ul>
              </nav>
            ))}
          </div>
        </div>

        <div class="c-footer__bar">
          <span class="c-footer__copy">{copyright} · {VERSION}</span>
          {legal.length > 0 || social.length > 0 ? (
            <span class="c-footer__meta">
              {legal.map((it) => <a href={it.href}>{it.title}</a>)}
              {social.map((s) => (
                <a href={s.url} target="_blank" rel="noopener noreferrer">
                  {s.label}
                </a>
              ))}
            </span>
          ) : null}
        </div>
      </Container>
    </footer>
  )
}

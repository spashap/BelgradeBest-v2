---
// Public analytics — free Google Analytics 4 only (Vercel Web Analytics removed
// to avoid its cost). Emitted in PRODUCTION ONLY, so `astro dev` ships no tags.
// Set PUBLIC_GA4_ID in the Vercel build env to switch it on.
const GA4 = import.meta.env.PUBLIC_GA4_ID;
const isProd = import.meta.env.PROD;
---
{
  isProd && GA4 ? (
    <Fragment>
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA4}`} />
      <script
        is:inline
        set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${GA4}');`}
      />
    </Fragment>
  ) : null
}

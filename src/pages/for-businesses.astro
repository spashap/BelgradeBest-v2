---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import PageIntro from "../components/PageIntro.astro";
import Container from "../components/Container.astro";
import SectionHead from "../components/SectionHead.astro";
import Snippet from "../components/Snippet.astro";
import Note from "../components/Note.astro";
import Schema from "../components/Schema.astro";
import { pageMetadata } from "../lib/metadata";
import { SITE, CONFIG } from "../lib/site";
import { breadcrumbSchema } from "../lib/schemas";

// The platform pitch page — outreach emails land here. Grows into the full
// claim flow (Phase 2 of KB/platform/PLATFORM-PLAN.md); for now it explains
// the free page + tools and collects interest by email.
const PATH = "/for-businesses";
const CONTACT_EMAIL = "admin@belgradebest.com";

const BADGE_EMBED = `<a href="${SITE.origin}/?utm_source=badge&utm_medium=embed">
  <img src="${SITE.origin}/badges/featured-on-belgradebest.svg"
       alt="Featured on BelgradeBest" width="200" height="56" loading="lazy"></a>`;

const meta = pageMetadata({
  title: "For Belgrade businesses — your free page on BelgradeBest",
  description:
    "Featured in our Belgrade guide? Get a free page for your restaurant, hotel, clinic or venue — photos, your info, a verified badge, and tools that work even if you have no website.",
  path: PATH,
});

const crumbs = [
  { name: CONFIG.chrome.article.breadcrumbRoot, href: "/" },
  { name: "For businesses" },
];

const schemas: object[] = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: meta.title,
    description: meta.description,
    url: `${SITE.origin}${PATH}`,
    inLanguage: CONFIG.brand.locale,
  },
  breadcrumbSchema([
    { name: CONFIG.chrome.article.breadcrumbRoot, url: SITE.origin },
    { name: "For businesses", url: `${SITE.origin}${PATH}` },
  ]),
];
---

<BaseLayout meta={meta}>
  <Breadcrumbs crumbs={crumbs} />
  <PageIntro
    eyebrow="For Belgrade businesses"
    title="Your free page on BelgradeBest"
    lede="BelgradeBest is the independent English guide foreign visitors read before they arrive — including for Expo 2027. If we've featured your restaurant, hotel, clinic, venue or pavilion, you can have your own page here: free, in English, and under your control."
  />

  <Container variant="read">
    <SectionHead title="What you get" />
    <ul>
      <li><strong>A free English page</strong> for your business — photos, your description, hours, links, and (for restaurants) your menu with prices.</li>
      <li><strong>Your own web address</strong> you can print on cards and menus — and if you don't have a website, this <em>is</em> your website.</li>
      <li><strong>Structured data built in</strong> so Google and AI assistants read your page correctly — we handle all the technical work.</li>
      <li><strong>Edit it yourself</strong>: no account, no password — a private link lets you update your page in minutes. Changes go live automatically.</li>
    </ul>
    <Note>
      <strong>Free means free.</strong> We never charge businesses for their page. BelgradeBest is
      an independent guide — how we fund it is explained on
      <a href="/how-we-make-money">how we make money</a>, and pages edited by a business are
      clearly marked "information provided by the business".
    </Note>

    <SectionHead
      title="No website? Point Google at your free page"
      intro="Google Business Profile lets any business set a website link. Use your BelgradeBest page:"
    />
    <ol>
      <li>Open <a href="https://business.google.com" rel="noopener">business.google.com</a> and sign in to your business profile.</li>
      <li>Choose <em>Edit profile → Contact → Website</em>.</li>
      <li>Paste your BelgradeBest page address and save. That's it — your Google Maps listing now links to a real English page about you.</li>
    </ol>

    <SectionHead
      title="Show it off: the badge"
      intro="Featured in one of our guides? Put the badge on your site — it links visitors to the guide that recommends you."
    />
    <p>
      <img
        src="/badges/featured-on-belgradebest.svg"
        alt="Featured on BelgradeBest badge preview"
        width="200"
        height="56"
        loading="lazy"
      />
    </p>
    <Snippet label="Badge embed code" code={BADGE_EMBED} />
    <p>
      Paste it anywhere HTML works — a WordPress <em>Custom HTML</em> block, a Wix/Squarespace
      <em>Embed</em> element, or your site footer. Writing about Expo 2027? There's also a free
      <a href="/expo-2027/countdown">embeddable countdown widget</a>.
    </p>

    <SectionHead title="Claim your page" />
    <p>
      Self-serve claiming opens soon. Until then, one email does it: write to
      <a href={`mailto:${CONTACT_EMAIL}?subject=Claim%20my%20page%20on%20BelgradeBest`}>{CONTACT_EMAIL}</a>
      from your business address with your business name, and we'll set up your page and send you
      the private edit link when claiming opens. You can also reach us via the
      <a href="/contact">contact page</a>.
    </p>
  </Container>

  <Schema schemas={schemas} />
</BaseLayout>

---
// Top-level listing route (pavilions). All rendering lives in ListingPage;
// only listings passing the thin-content guard build (lib/listings.ts).
import ListingPage from "../../../layouts/ListingPage.astro";
import { listingsForLeg, type Listing } from "../../../lib/listings";

export function getStaticPaths() {
  return listingsForLeg("expo-2027").map((l) => ({
    params: { slug: l.slug },
    props: { listing: l },
  }));
}

const { listing } = Astro.props as { listing: Listing };
---

<ListingPage listing={listing} />

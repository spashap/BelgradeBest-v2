---
// T4: one layout for every listing profile — top-level (pavilion, restaurant…)
// and child (exhibitor/booth under a parent). Renders ONLY editorial fields;
// the operator-only `contact`/`outreach` fields must never appear here.
import BaseLayout from "./BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import PageIntro from "../components/PageIntro.astro";
import Container from "../components/Container.astro";
import SectionHead from "../components/SectionHead.astro";
import Note from "../components/Note.astro";
import Faq from "../components/Faq.astro";
import Schema from "../components/Schema.astro";
import { pageMetadata } from "../lib/metadata";
import { SITE, EXPO, CONFIG } from "../lib/site";
import { articleSchema, breadcrumbSchema, faqSchema } from "../lib/schemas";
import { metaTrim } from "../lib/text";
import { ogImage } from "../lib/og";
import {
  listingHref,
  listingsIndexable,
  childrenOf,
  parentOf,
  SECTION,
  type Listing,
} from "../lib/listings";

interface Props {
  listing: Listing;
}
const { listing } = Astro.props;

const path = listingHref(listing);
const url = `${SITE.origin}${path}`;
const section = SECTION[listing.leg] ?? "places";
const hubPath = `/${listing.leg}/${section}`;
const parent = parentOf(listing);
const children = childrenOf(listing.leg, listing.slug);
const short = listing.shortName ?? listing.name;

const STATUS_LABEL: Record<string, string> = {
  announced: "Plans announced",
  tender: "Tender under way",
  construction: "Under construction",
  "concept-only": "Concept reported",
};
const statusLabel = listing.status ? (STATUS_LABEL[listing.status] ?? listing.status) : null;
const kind = listing.type === "pavilion" ? "National pavilion" : listing.type === "exhibitor" ? "Exhibitor" : "Participant";

const meta = pageMetadata({
  title: `${listing.name} at Expo 2027 Belgrade — theme & plans`,
  description: metaTrim(listing.summary),
  path,
  noindex: !listingsIndexable,
  image: ogImage(`pavilion-${listing.slug}`),
  imageAlt: `${listing.name} at Expo 2027 Belgrade — profile on BelgradeBest`,
});

const crumbTrail = [
  { name: CONFIG.chrome.article.breadcrumbRoot, href: "/" },
  { name: EXPO.shortName, href: "/expo-2027" },
  { name: "Pavilions", href: hubPath },
  ...(parent ? [{ name: parent.shortName ?? parent.name, href: listingHref(parent) }] : []),
  { name: short },
];

const schemas: object[] = [
  articleSchema({
    title: `${listing.name} at Expo 2027 Belgrade`,
    description: metaTrim(listing.summary),
    url,
    dateModified: listing.updated,
  }),
  breadcrumbSchema(
    crumbTrail.map((c) => ({ name: c.name, url: `${SITE.origin}${c.href ?? path}` })),
  ),
];

// Expo dates from the config master (one source for the fact).
const fmtDate = (d: string) =>
  new Date(d).toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" });
const expoDates = `${fmtDate(EXPO.startDate)} – ${fmtDate(EXPO.endDate)}`;

const facts = listing.blocks.facts ?? [];
const about = listing.blocks.about ?? [];
const quotes = listing.blocks.quotes ?? [];
const sources = listing.links?.sources ?? [];
const faqs = listing.faqs ?? [];
if (faqs.length > 0) schemas.push(faqSchema(faqs));
---

<BaseLayout meta={meta}>
  <Breadcrumbs crumbs={crumbTrail} />
  <PageIntro
    eyebrow={`Expo 2027 · ${kind}${statusLabel ? ` · ${statusLabel}` : ""}`}
    title={listing.name}
    lede={listing.summary}
  />

  <Container variant="read">
    {listing.claimed && (
      <Note tone="gold">
        <strong>Managed by the {short} team.</strong> The information on this page is provided
        and kept current by the listing's own representatives; sources and editorial framing
        remain ours.
      </Note>
    )}

    {facts.length > 0 && (
      <>
        <SectionHead title="At a glance" />
        <div class="c-data-table">
          <table>
            <tbody>
              {facts.map((f) => (
                <tr>
                  <th scope="row">{f.label}</th>
                  <td>
                    {f.value}
                    {f.source ? (
                      <>
                        {" "}
                        <a href={f.source} rel="nofollow noopener">
                          [source]
                        </a>
                      </>
                    ) : null}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </>
    )}

    {about.length > 0 && (
      <>
        <SectionHead title={listing.claimed ? `About ${short}` : "What's been announced"} />
        {about.map((p) => <p>{p}</p>)}
      </>
    )}

    {(listing.images ?? []).length > 0 && (
      <>
        <SectionHead title="Photos" />
        <div class="c-grid">
          {(listing.images ?? []).map((src, i) => (
            <figure>
              <img
                src={src}
                alt={`${listing.name} — photo ${i + 1}`}
                loading="lazy"
                decoding="async"
                width="640"
                height="480"
                style="width:100%;height:auto;border-radius:var(--radius);border:1px solid var(--line)"
              />
            </figure>
          ))}
        </div>
      </>
    )}

    {quotes.map((q) => (
      <blockquote>
        “{q.quote}” — {q.who}
        {q.source ? (
          <>
            {" "}
            <a href={q.source} rel="nofollow noopener">
              [source]
            </a>
          </>
        ) : null}
      </blockquote>
    ))}

    {children.length > 0 && (
      <>
        <SectionHead
          title={`Exhibitors & related participants`}
          intro={`Organizations presenting under or alongside the ${short} presence — each with its own profile.`}
        />
        <ul>
          {children.map((c) => (
            <li>
              <a href={listingHref(c)}>{c.name}</a> — {c.summary.split(". ")[0]}.
            </li>
          ))}
        </ul>
      </>
    )}

    {parent && (
      <p>
        Part of the <a href={listingHref(parent)}>{parent.name}</a> presence at {EXPO.shortName}.
      </p>
    )}

    <SectionHead title={`Where to find the ${short} ${listing.type === "pavilion" ? "pavilion" : "presence"}`} />
    <p>
      National pavilions sit in the <strong>International Participant Area</strong> of the
      25-hectare Expo site at {EXPO.venue}, in the western part of Belgrade — the zone that
      becomes the city's new Belgrade Fair after the event. The site is about
      <strong> 5 km from Nikola Tesla Airport</strong> and roughly
      <strong> 13.5 km southwest of central Belgrade</strong> (official planning figures), so
      if you fly in, you land closer to the Expo grounds than to town. Exact positions within
      the zones haven't been published yet; we'll add the location when the site plan lands.
    </p>

    <SectionHead title="Visiting — the practical context" />
    <ul>
      <li>
        <strong>Dates:</strong> {expoDates} ({EXPO.classification}, 93 days). Each participating
        country also gets a National Day — that schedule isn't published yet.
      </li>
      <li>
        <strong>Getting there:</strong> Belgrade's regular city public transport is currently
        free to ride; a taxi or ride-hail app (CarGo, Yandex Go) covers the ~13.5 km from the
        centre. A new airport–Surčin railway is under construction but not yet running — the
        honest status of every route is in <a href="/expo-2027/getting-there">getting to Expo 2027</a>.
      </li>
      <li>
        <strong>Tickets:</strong> not on sale yet — what's actually known is tracked in the{" "}
        <a href="/expo-2027/tickets">Expo 2027 tickets guide</a>.
      </li>
      <li>
        <strong>Where to stay:</strong> the airport-side vs city-centre trade-off is weighed in{" "}
        <a href="/expo-2027/where-to-stay-for-expo">where to stay for Expo 2027</a>.
      </li>
    </ul>

    {faqs.length > 0 && (
      <>
        <SectionHead title={`${short} at Expo 2027 — quick answers`} />
        <Faq faqs={faqs} />
      </>
    )}

    <Note>
      <strong>How this page is maintained.</strong> This profile is compiled editorially from
      the public sources listed below — we mark plans as announced or reported, never guessed.
      Represent {short}? You can <a href="/for-businesses">claim this page for free</a> and
      keep it current yourself.
    </Note>

    {sources.length > 0 && (
      <>
        <SectionHead title="Sources" />
        <ul>
          {sources.map((s) => (
            <li>
              <a href={s.url} rel="nofollow noopener">
                {s.url}
              </a>
              {s.note ? ` — ${s.note}` : ""}
            </li>
          ))}
        </ul>
      </>
    )}

    <p>
      More on the Expo: <a href="/expo-2027/tracker">participant tracker</a> ·{" "}
      <a href={hubPath}>all pavilion profiles</a> ·{" "}
      <a href="/expo-2027/participants">who's coming to Expo 2027</a> ·{" "}
      <a href="/expo-2027">the full Expo 2027 guide</a>
    </p>
  </Container>

  <Schema schemas={schemas} />
</BaseLayout>

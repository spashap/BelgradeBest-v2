---
import { render } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import PageIntro from "../components/PageIntro.astro";
import Container from "../components/Container.astro";
import Placeholder from "../components/Placeholder.astro";
import ArticleHero from "../components/ArticleHero.astro";
import ArticleToc from "../components/ArticleToc.astro";
import StayLinks from "../components/StayLinks.astro";
import InternalLinkBlock from "../components/InternalLinkBlock.astro";
import Schema from "../components/Schema.astro";
import { articleSchema, faqSchema, breadcrumbSchema } from "../lib/schemas";
import { SITE, CONFIG, interp } from "../lib/site";
import { clusterBySlug } from "../lib/clusters";
import { heroForPath } from "../lib/hero";
import { relatedFor } from "../lib/links";
import { pageMetadata } from "../lib/metadata";
import type { Article } from "../lib/articles";

// Leg-agnostic T3 article template. Per-leg chrome (eyebrow, breadcrumb root,
// read-next copy, Expo-only Event schema) is derived from the cluster registry.
interface Props {
  entry: Article;
}
const { entry } = Astro.props;
const d = entry.data;
const leg = d.leg;
const href = `/${leg}/${d.slug}`;
const url = SITE.origin + href;

const c = clusterBySlug(leg);
const eyebrow = c?.eyebrow ?? leg;
const crumbRoot = { name: c?.title ?? leg, href: SITE.origin + (c?.href ?? `/${leg}`) };
const rn =
  leg === "expo-2027" ? CONFIG.chrome.article.readNextExpo : CONFIG.chrome.article.readNextEvergreen;

const resolvedHero = heroForPath(href, d.heroAlt ?? d.heroLabel);
const heroAbs = resolvedHero ? SITE.origin + resolvedHero.src : undefined;

const meta = pageMetadata({
  title: d.title,
  description: d.description,
  path: href,
  noindex: d.noindex,
  image: resolvedHero?.src,
  imageAlt: d.heroAlt ?? resolvedHero?.alt ?? d.title,
});

const { Content, headings } = await render(entry);
const targets = await relatedFor(leg, d.slug);

// Human-readable freshness stamp (same source as schema dateModified).
const updatedLabel = (() => {
  const t = Date.parse(d.lastUpdated);
  if (Number.isNaN(t)) return null;
  return new Date(t).toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" });
})();

// Event JSON-LD lives on the /expo-2027 hub only (LegHubLayout) — re-declaring
// it on every expo article duplicated the Event with inconsistent images.
const schemas: object[] = [
  articleSchema({ title: d.title, description: d.description, url, dateModified: d.lastUpdated, imageUrl: heroAbs }),
  breadcrumbSchema([
    { name: CONFIG.chrome.article.breadcrumbRoot, url: SITE.origin },
    { name: crumbRoot.name, url: crumbRoot.href },
    { name: d.shortTitle, url },
  ]),
];
if (d.faqs && d.faqs.length > 0) schemas.push(faqSchema(d.faqs));
---
<BaseLayout meta={meta}>
  <PageIntro eyebrow={eyebrow} title={d.title} lede={d.lede} />

  {
    updatedLabel ? (
      <Container variant="article">
        <p class="c-article-meta">Updated {updatedLabel} · Source-checked by the BelgradeBest editorial process</p>
      </Container>
    ) : null
  }

  <Container>
    {
      resolvedHero ? (
        <ArticleHero
          src={resolvedHero.src}
          srcset={resolvedHero.srcset}
          sizes={resolvedHero.sizes}
          alt={d.heroAlt ?? resolvedHero.alt}
        />
      ) : (
        <Placeholder ratio="21/9" label={d.heroLabel} />
      )
    }
  </Container>

  <Container variant="article">
    <div class="u-stack-lg">
      <ArticleToc headings={headings} />
      <article class="c-article">
        <Content />
      </article>
      {
        d.unknowns && d.unknowns.length > 0 ? (
          <aside class="c-unknowns">
            <h2>Still unknown or unconfirmed</h2>
            <ul>{d.unknowns.map((u: string) => <li>{u}</li>)}</ul>
          </aside>
        ) : null
      }
      <StayLinks targets={d.stayTargets} />
    </div>
  </Container>

  <div class="u-stack-lg"></div>

  <InternalLinkBlock eyebrow={rn.eyebrow} title={interp(rn.title)} intro={rn.intro} targets={targets} />

  <Schema schemas={schemas} />
</BaseLayout>
